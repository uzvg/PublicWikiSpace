<!-- Action to set tiddlywiki flascards note field value -->
\widget $action.set-note(dataTiddler,noteId,jsonData)
\function get-target-data() [<dataTiddler>get[text]else[]jsonset:json<noteId>,<jsonData>format:json[2]]
<$action-setfield
		$tiddler=<<dataTiddler>>
		text=<<get-target-data>>/>
\end

